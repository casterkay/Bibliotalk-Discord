# Copy this file to deploy/local/.env and fill in your values.

EMOS_BASE_URL=https://your-evermemos-instance.example.com
EMOS_API_KEY=replace-me
GOOGLE_API_KEY=replace-me
BIBLIOTALK_DB_PATH=/data/bibliotalk.db
LOG_LEVEL=INFO

# Figure slug used by one-figure local stack.
BIBLIOTALK_FIGURE=alan-watts

# Discord token fallback and per-figure token.
DISCORD_TOKEN=
DISCORD_TOKEN_ALAN_WATTS=replace-me

# Optional memory page service bind settings.
MEMORY_PAGE_HOST=0.0.0.0
MEMORY_PAGE_PORT=8080
