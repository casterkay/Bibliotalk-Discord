# Copy to `.env` at repo root and fill in your values.

# EverMemOS
EMOS_BASE_URL=
EMOS_API_KEY=

# Gemini (Google ADK)
GOOGLE_API_KEY=

# Discord bot token (single-bot runtime)
DISCORD_TOKEN=

# Optional: sync slash commands to a single guild for fast iteration
DISCORD_COMMAND_GUILD_ID=

# Matrix homeserver + appservice tokens
MATRIX_HOMESERVER_URL=http://localhost:8008
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=

# Synapse admin (for scripted local provisioning)
MATRIX_SERVER_NAME=localhost
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=
MATRIX_REGISTRATION_SHARED_SECRET=

# SQLite database path (optional; defaults to ~/.bibliotalk/bibliotalk.db)
BIBLIOTALK_DB_PATH=

# Public base URL used in inline memory links (default: https://www.bibliotalk.space)
BIBLIOTALK_WEB_URL=

# Structured logging level
LOG_LEVEL=INFO

# Optional: if Discord is only reachable via proxy, export standard proxy env vars.
# Example (Clash default):
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Optional: enable Gemini-based facilitator/concierge (defaults to deterministic fallback)
BIBLIOTALK_ENABLE_AI_ROUTER=
BIBLIOTALK_ENABLE_AI_CONCIERGE=

# Optional memory page service bind settings
MEMORY_PAGE_HOST=0.0.0.0
MEMORY_PAGE_PORT=8080
