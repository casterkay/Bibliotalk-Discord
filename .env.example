# Google Gemini key used for Gemini model calls
GOOGLE_API_KEY=

# PocketBase (local dev canonical store)
POCKETBASE_URL=http://localhost:8090
POCKETBASE_SUPERUSER_EMAIL=admin@bibliotalk.local
POCKETBASE_SUPERUSER_PASSWORD=

# Supabase project URL and service role key (blueprint/production target; optional for local dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# EverMemOS base endpoint, e.g. http://localhost:8000
EMOS_BASE_URL=
EMOS_API_KEY=
EMOS_ORG_ID=
EMOS_SPACE_ID=

# AWS region for Bedrock-backed models (default us-east-1)
AWS_REGION=us-east-1

# Matrix homeserver + appservice tokens
MATRIX_HOMESERVER_URL=
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=

# Synapse admin (for scripted local provisioning)
MATRIX_SERVER_NAME=localhost
MATRIX_ADMIN_USER=bt_admin
MATRIX_ADMIN_PASSWORD=

# Structured logging level
LOG_LEVEL=INFO
