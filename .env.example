# Google Gemini key used for Gemini model calls
GOOGLE_API_KEY=

# agents_service relational DB (local dev default is SQLite)
# If omitted, agents_service will default to `./.agents_service/bibliotalk.sqlite`.
DATABASE_URL=sqlite+aiosqlite:///./.agents_service/bibliotalk.sqlite

# EverMemOS base endpoint, e.g. http://localhost:8000
EMOS_BASE_URL=
EMOS_API_KEY=
EMOS_ORG_ID=
EMOS_SPACE_ID=

# AWS region for Bedrock-backed models (default us-east-1)
AWS_REGION=us-east-1

# Discord bot token and guild ID for registering commands (optional)
DISCORD_TOKEN=
DISCORD_COMMAND_GUILD_ID=

# Matrix homeserver + appservice tokens
MATRIX_HOMESERVER_URL=
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=

# Synapse admin (for scripted local provisioning)
MATRIX_SERVER_NAME=localhost
MATRIX_ADMIN_USER=bt_admin
MATRIX_ADMIN_PASSWORD=

# Structured logging level
LOG_LEVEL=INFO
